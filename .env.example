# Copy this file to .env and fill in real values (never commit .env)

# Payload CMS secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-a-long-random-string

# SQLite (dev) — switch to postgres:// for production
DATABASE_URL=file:./payload.db

# Production only — swap SQLite adapter for @payloadcms/db-postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email (Phase 5 — contact form)
# RESEND_API_KEY=re_...
